FROM appwrite/base:1.2.0 AS final
LABEL maintainer="team@appwrite.io"

WORKDIR /usr/src/code

# Composer binary (for running scripts inside the container)
COPY --from=composer:2.7 /usr/bin/composer /usr/local/bin/composer

COPY ./src /usr/src/code/src
COPY ./tests /usr/src/code/tests
COPY ./phpunit.xml /usr/src/code/phpunit.xml
COPY ./composer.json ./composer.lock ./phpstan.neon /usr/src/code/
COPY ./vendor /usr/src/code/vendor

EXPOSE 80

CMD ["php", "tests/e2e/server-swoole.php"]
